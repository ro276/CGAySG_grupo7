<span class=3D"hljs-function"><span class=3D"hljs-keyword">function</span> =
<span class=3D"hljs-title">dibujarEstructuraConica</span>(<span class=3D"hl=
js-params">cx, cy, r, h, d, lados</span>) </span>{
  <span class=3D"hljs-comment">// Calculamos los v=C3=A9rtices del pol=C3=
=ADgono base (ej. un cuadrado o rombo)</span>
  <span class=3D"hljs-keyword">let</span> vertices =3D [];
  <span class=3D"hljs-keyword">for</span> (<span class=3D"hljs-keyword">let=
</span> i =3D <span class=3D"hljs-number">0</span>; i &lt;=3D lados; i++) {
    <span class=3D"hljs-keyword">let</span> angle =3D TWO_PI / lados * i + =
PI/<span class=3D"hljs-number">4</span>; <span class=3D"hljs-comment">// +P=
I/4 para rotar y que sea sim=C3=A9trico</span>
    <span class=3D"hljs-keyword">let</span> vx =3D cx + cos(angle) * r;
    <span class=3D"hljs-keyword">let</span> vy =3D cy + h + sin(angle) * (r=
 * <span class=3D"hljs-number">0.3</span>); <span class=3D"hljs-comment">//=
 Multiplicado por 0.3 para aplanar la perspectiva</span>
    vertices.push({<span class=3D"hljs-attr">x</span>: vx, <span class=3D"h=
ljs-attr">y</span>: vy});
  }

  <span class=3D"hljs-comment">// Por cada lado del pol=C3=ADgono, trazamos=
 miles de l=C3=ADneas hacia el centro</span>
  <span class=3D"hljs-keyword">for</span> (<span class=3D"hljs-keyword">let=
</span> i =3D <span class=3D"hljs-number">0</span>; i &lt; lados; i++) {
    <span class=3D"hljs-keyword">let</span> p1 =3D vertices[i];
    <span class=3D"hljs-keyword">let</span> p2 =3D vertices[i+<span class=
=3D"hljs-number">1</span>];

    <span class=3D"hljs-keyword">for</span> (<span class=3D"hljs-keyword">l=
et</span> j =3D <span class=3D"hljs-number">0</span>; j &lt; d; j++) {
      <span class=3D"hljs-comment">// Interpolar puntos a lo largo del bord=
e del pol=C3=ADgono</span>
      <span class=3D"hljs-keyword">let</span> inter =3D j / d;
      <span class=3D"hljs-keyword">let</span> xEdge =3D lerp(p1.x, p2.x, in=
ter);
